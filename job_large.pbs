#!/bin/bash
#PBS -N wer_large
#PBS -l select=1:ngpus=1:ncpus=8:mem=64gb
#PBS -l walltime=6:00:00
#PBS -P personal-csshivam
#PBS -o logs/large.log
#PBS -e logs/large.err
#PBS -j oe

module load cuda/12.2.1
export LD_LIBRARY_PATH=/app/libs/cudnn/12-8.9.4.25/lib:$LD_LIBRARY_PATH

source /app/apps/miniforge3/25.3.1/etc/profile.d/conda.sh
conda activate whisper

export HF_DATASETS_CACHE=/scratch/users/ntu/csshivam/hf_cache
export WHISPER_CACHE=/scratch/users/ntu/csshivam/whisper_cache
mkdir -p $HF_DATASETS_CACHE $WHISPER_CACHE

cd /scratch/users/ntu/csshivam/Tie_shorts

python task3_whisper_large/wer_whisper_large.py
